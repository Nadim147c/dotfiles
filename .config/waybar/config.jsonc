{
    "layer": "bottom",
    "position": "top",
    "height": 40,
    "exclusive": true,
    "gtk-layer-shell": true,
    "passthrough": false,
    "fixed-center": true,
    "reload_style_on_change": true,
    "margin": "0 8px",
    "modules-left": ["hyprland/workspaces", "wlr/taskbar", "custom/lyrics"],
    "modules-center": [],
    "modules-right": [
        "custom/docker",
        // "cpu",
        // "memory",
        "network",
        "custom/pipewire",
        "custom/mic",
        "tray",
        // "custom/wallpaper",
        "custom/awake",
        "clock",
        "custom/notification",
        "custom/power",
    ],
    "custom/lyrics": {
        "interval": 1,
        "signal": 4,
        "return-type": "json",
        "format": "{icon}  {0}",
        "format-icons": {
            "playing": "´üï",
            "paused": "´üî",
            "lyric": "¯ÖÄ",
        },
        "exec": "waybar-lyric --max-length 100",
        "on-click": "waybar-lyric --toggle",
    },
    "custom/docker": {
        "interval": 5,
        "signal": 4,
        "return-type": "json",
        "format": "{icon} {0}",
        "format-icons": ["´êş"],
        "exec-if": "! docker ps --quiet",
        "exec": "waybar-docker.nu",
    },
    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{id}",
        "all-outputs": true,
        "disable-scroll": false,
        "active-only": false,
    },
    "hyprland/window": {
        "format": "{class}",
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 17,
        "spacing": 0,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "on-click-right": null,
        "ignore-list": ["Picture-in-Picture", "Picture in Picture", "Picture in picture", "ChatGPT"],
        "app_ids-mapping": {
            "vesktop": "discord",
            "equibop": "discord",
        },
    },
    "tray": {
        "show-passive-items": true,
        "spacing": 10,
    },
    "clock": {
        "format": "´Çù {:%I:%M%p}",
        "tooltip-format": "<big>{:%d %B %Y}</big>\n<tt>{calendar}</tt>",
        "on-click": "gnome-calendar",
    },
    "network": {
        "interval": 5,
        "format-wifi": "´ç½ {bandwidthTotalBytes}",
        "format-ethernet": "¯¢ä {bandwidthTotalBytes}",
        "format-linked": "¾░øÁ (No IP)",
        "format-disconnected": "´ü▓ ",
        "tooltip-format": "Upload Speed: {bandwidthUpBytes}\nDownload Speed: {bandwidthDownBytes}",
    },
    "cpu": {
        "format": "´ïø {usage}%",
        "tooltip": true,
        "interval": 1,
    },
    "memory": {
        "format": "¯┐à <span><small><sup> </sup></small></span>{used:0.1f}GiB",
        "tooltip": true,
        "tooltip-format": "Ram: {percentage}% {used}/{total}GiB\nSwap: {swapPercentage}% {swapUsed}/{swapTotal}GiB",
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "¾░éÜ<span foreground='red'><small><sup>Ô¼ñ</sup></small></span>",
            // Fixes Nerdfont width: add half with space
            "none": "¾░éÜ<span><small><sup> </sup></small></span>",
            "dnd-notification": "¾░éø<span foreground='red'><small><sup>Ô¼ñ</sup></small></span>",
            // Fixes Nerdfont width: add half with space
            "dnd-none": "¾░éø<span><small><sup> </sup></small></span>",
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
    },
    "custom/weather": {
        "interval": 2,
        "signal": 4,
        "return-type": "json",
        "format": "{icon} {0}",
        "format-icons": {
            "clear": "¯îı",
            "cloudy": "¯îî",
            "fog": "¾░ûæ",
            "drizzle": "¯Ä¡",
            "rain": "¾░ûù",
            "snow": "¯îÜ",
            "thunderstorm": "¯îØ",
        },
        "exec-if": "which waytune",
        "exec": "waytune weather --unit c",
    },
    "custom/mic": {
        "interval": 1,
        "signal": 4,
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "normal": "¯┤â",
            "muted": "¯┐å ",
        },
        "exec": "waybar-mic.nu",
        "on-click": "waybar-mic.nu --toggle",
    },
    "custom/awake": {
        "interval": 1,
        "signal": 4,
        "format": "´â┤ ",
        "tooltip-format": "Stay Awake is enabled",
        "exec": "echo awake",
        "exec-if": "! waybar-awake.nu --check",
        "on-click": "waybar-awake.nu --toggle",
    },
    "custom/pipewire": {
        "interval": 1,
        "signal": 4,
        "return-type": "json",
        "format": "{icon} {percentage}%",
        "format-icons": {
            "normal": ["´ÇĞ", "´Çğ", "´Ç¿"],
            "muted": "¯╗¿ ",
        },
        "exec": "waybar-pipewire.nu",
        "on-click": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ '2%+'",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ '2%-'",
    },
    "custom/wallpaper": {
        "tooltip-format": "Change wallpaper",
        "on-click": "$HOME/.config/hypr/scripts/swww.sh",
        // Fixes Nerdfont width: add half with space
        "format": "¯╣▓<span><small><sup> </sup></small></span>",
    },
    "custom/power": {
        "tooltip-format": "Open Power Menu",
        "on-click": "wlogout -p layer-shell -b 2 &",
        // Fixes Nerdfont width: add half with space
        "format": "´Çæ<span><small><sup> </sup></small></span>",
    },
}
