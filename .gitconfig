[include]
	path = ~/.gitconfig.local
[core]
	pager = delta --line-numbers --hunk-header-style=omit
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default
[alias]
	grep = !rg --color=always -S
	fork = !gh repo fork
	quick-stats = !git-quick-stats

	down = pull --rebase
	open = browse
